<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GreenVision.ViewModels"
             xmlns:models="using:GreenVision.Models"
             xmlns:converters="using:GreenVision.Converters"
             x:Class="GreenVision.Views.LogsView"
             x:DataType="vm:LogsViewModel"
             Background="Transparent">

  <UserControl.Resources>
    <converters:LogSeverityToColorConverter x:Key="SeverityColor" />
  </UserControl.Resources>

  <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="12">

    <!-- Header -->
    <StackPanel Grid.Row="0" Spacing="2" Margin="0,0,0,12">
      <TextBlock Text="System Logs" Classes="page-title" />
      <TextBlock Text="Real-time event log — system, sensor, alarm, and inspection events" Classes="muted" />
    </StackPanel>

    <!-- Stats row -->
    <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" Margin="0,0,0,12">
      <Border Grid.Column="0" Background="#25FFFFFF" CornerRadius="10"
              BorderBrush="#30FFFFFF" BorderThickness="1" Padding="14,10" Margin="0,0,6,0">
        <StackPanel Spacing="2">
          <TextBlock Text="TOTAL ENTRIES" FontSize="9" Foreground="#6A8099" FontWeight="SemiBold" />
          <TextBlock Text="{Binding TotalCount}" FontSize="22" FontWeight="Bold" Foreground="#F0F6FF" />
        </StackPanel>
      </Border>
      <Border Grid.Column="1" Background="#25FFFFFF" CornerRadius="10"
              BorderBrush="#30FFFFFF" BorderThickness="1" Padding="14,10" Margin="3,0">
        <StackPanel Spacing="2">
          <TextBlock Text="ERRORS" FontSize="9" Foreground="#6A8099" FontWeight="SemiBold" />
          <TextBlock Text="{Binding ErrorCount}" FontSize="22" FontWeight="Bold" Foreground="#FF4466" />
        </StackPanel>
      </Border>
      <Border Grid.Column="2" Background="#25FFFFFF" CornerRadius="10"
              BorderBrush="#30FFFFFF" BorderThickness="1" Padding="14,10" Margin="3,0">
        <StackPanel Spacing="2">
          <TextBlock Text="WARNINGS" FontSize="9" Foreground="#6A8099" FontWeight="SemiBold" />
          <TextBlock Text="{Binding WarnCount}" FontSize="22" FontWeight="Bold" Foreground="#F59E0B" />
        </StackPanel>
      </Border>
      <Border Grid.Column="3" Background="#25FFFFFF" CornerRadius="10"
              BorderBrush="#30FFFFFF" BorderThickness="1" Padding="14,10" Margin="6,0,0,0">
        <StackPanel Spacing="4" VerticalAlignment="Center">
          <Button Content="⬇  Export CSV" Classes="primary"
                  Command="{Binding ExportCsvCommand}"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Padding="8,6" />
          <Button Content="✕  Clear Filter"
                  Command="{Binding ClearFilterCommand}"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Padding="8,6" />
        </StackPanel>
      </Border>
    </Grid>

    <!-- Filter bar -->
    <Grid Grid.Row="2" ColumnDefinitions="*,160,160" Margin="0,0,0,10">
      <TextBox Grid.Column="0" Text="{Binding SearchText}"
               Watermark="Search messages..." Margin="0,0,8,0" />
      <ComboBox Grid.Column="1" ItemsSource="{Binding Categories}"
                SelectedItem="{Binding SelectedCategory}"
                Margin="0,0,8,0" HorizontalAlignment="Stretch" />
      <ComboBox Grid.Column="2" ItemsSource="{Binding Severities}"
                SelectedItem="{Binding SelectedSeverity}"
                HorizontalAlignment="Stretch" />
    </Grid>

    <!-- Log entries -->
    <Border Grid.Row="3" Background="#25FFFFFF" CornerRadius="12"
            BorderBrush="#30FFFFFF" BorderThickness="1">
      <Grid RowDefinitions="Auto,*">
        <!-- Column headers -->
        <Grid Grid.Row="0" ColumnDefinitions="155,55,80,100,*"
              Background="#25FFFFFF" Margin="0" >
          <Border Grid.ColumnSpan="5" CornerRadius="12,12,0,0"
                  Background="#25FFFFFF" />
          <TextBlock Grid.Column="0" Text="TIMESTAMP" FontSize="10" FontWeight="SemiBold"
                     Foreground="#6A8099" Margin="16,10,0,10" />
          <TextBlock Grid.Column="1" Text="SEV" FontSize="10" FontWeight="SemiBold"
                     Foreground="#6A8099" Margin="0,10" VerticalAlignment="Center" />
          <TextBlock Grid.Column="2" Text="CATEGORY" FontSize="10" FontWeight="SemiBold"
                     Foreground="#6A8099" Margin="0,10" VerticalAlignment="Center" />
          <TextBlock Grid.Column="3" Text="SOURCE" FontSize="10" FontWeight="SemiBold"
                     Foreground="#6A8099" Margin="0,10" VerticalAlignment="Center" />
          <TextBlock Grid.Column="4" Text="MESSAGE" FontSize="10" FontWeight="SemiBold"
                     Foreground="#6A8099" Margin="0,10,16,10" VerticalAlignment="Center" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding DisplayedEntries}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:LogEntry">
                <Border BorderBrush="#30FFFFFF" BorderThickness="0,0,0,1">
                  <Grid ColumnDefinitions="155,55,80,100,*" Margin="0,1">
                    <TextBlock Grid.Column="0"
                               Text="{Binding FormattedTimestamp}"
                               FontSize="11" Foreground="#6A8099"
                               FontFamily="Consolas,monospace"
                               VerticalAlignment="Center" Margin="16,6,0,6" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding SeverityText}"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{Binding Severity, Converter={StaticResource SeverityColor}}"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding Category}"
                               FontSize="11" Foreground="#5A7090"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="3"
                               Text="{Binding Source}"
                               FontSize="11" Foreground="#00F0C8"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="4"
                               Text="{Binding Message}"
                               FontSize="11" Foreground="#F0F6FF"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" Margin="0,6,16,6" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>

  </Grid>
</UserControl>
