<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GreenVision.ViewModels"
        xmlns:converters="using:GreenVision.Converters"
        xmlns:mi="using:Material.Icons.Avalonia"
        x:Class="GreenVision.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="FabSentinel — AI Fab Safety Intelligence"
        Width="1400" Height="860"
        MinWidth="1100" MinHeight="700"
        WindowStartupLocation="CenterScreen">

  <Window.Background>
    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
      <GradientStop Color="#040C1A" Offset="0" />
      <GradientStop Color="#061220" Offset="0.6" />
      <GradientStop Color="#050E1C" Offset="1" />
    </LinearGradientBrush>
  </Window.Background>

  <Window.Resources>
    <converters:StringToColorBrushConverter x:Key="StringToBrush" />
    <converters:StringToMaterialIconKindConverter x:Key="StringToIcon" />
  </Window.Resources>

  <Grid RowDefinitions="56,*,28">

    <!-- ═══ TOP HEADER BAR (glass) ═══ -->
    <Border Grid.Row="0"
            Background="#1AFFFFFF"
            BorderBrush="#25FFFFFF" BorderThickness="0,0,0,1"
            BoxShadow="0 2 24 0 #1A000000">
      <Grid ColumnDefinitions="Auto,*,Auto" Margin="20,0">

        <!-- Logo + App Name + Page Title -->
        <StackPanel Grid.Column="0" Orientation="Horizontal"
                    VerticalAlignment="Center" Spacing="12">

          <!-- GV logo badge -->
          <Border Width="34" Height="34" CornerRadius="10"
                  Background="#00F0C8"
                  BoxShadow="0 0 16 0 #5000F0C8">
            <TextBlock Text="FS" FontSize="13" FontWeight="Bold"
                       Foreground="#040C1A"
                       VerticalAlignment="Center" HorizontalAlignment="Center" />
          </Border>

          <StackPanel VerticalAlignment="Center" Spacing="1">
            <TextBlock Text="FabSentinel" FontSize="14" FontWeight="Bold"
                       Foreground="#F0F6FF" />
            <TextBlock Text="Fab Safety Intelligence" FontSize="10"
                       Foreground="#5A7090" />
          </StackPanel>

          <!-- Divider -->
          <Border Width="1" Background="#20FFFFFF" Margin="4,10" />

          <TextBlock Text="{Binding SelectedNavItem.Title}"
                     FontSize="13" FontWeight="SemiBold"
                     Foreground="#A0C4D8"
                     VerticalAlignment="Center" />
        </StackPanel>

        <!-- Right status area -->
        <StackPanel Grid.Column="2" Orientation="Horizontal"
                    VerticalAlignment="Center" Spacing="10">

          <!-- Alarm badge -->
          <Border CornerRadius="8" Padding="10,5"
                  Background="{Binding AlarmColor, Converter={StaticResource StringToBrush}}"
                  BoxShadow="0 0 12 0 #30000000">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Ellipse Width="6" Height="6" Fill="White" VerticalAlignment="Center" />
              <TextBlock Text="{Binding AlarmStatus}" FontSize="11" FontWeight="Bold"
                         Foreground="White" VerticalAlignment="Center" />
            </StackPanel>
          </Border>

          <!-- Online indicator -->
          <Border Background="#0A00F0C8" CornerRadius="8" Padding="10,5"
                  BorderBrush="#2000F0C8" BorderThickness="1">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <Ellipse Width="6" Height="6" VerticalAlignment="Center">
                <Ellipse.Fill>
                  <SolidColorBrush Color="#00F0C8" />
                </Ellipse.Fill>
              </Ellipse>
              <TextBlock Text="ONLINE" FontSize="11" FontWeight="SemiBold"
                         Foreground="#00F0C8" VerticalAlignment="Center" />
            </StackPanel>
          </Border>

          <!-- DateTime -->
          <Border Background="#1AFFFFFF" CornerRadius="8" Padding="12,5"
                  BorderBrush="#20FFFFFF" BorderThickness="1">
            <TextBlock Text="{Binding CurrentDateTime}" FontSize="12"
                       FontFamily="Consolas,Courier New,monospace"
                       Foreground="#00F0C8" VerticalAlignment="Center" />
          </Border>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ═══ SIDEBAR + CONTENT ═══ -->
    <Grid Grid.Row="1" ColumnDefinitions="168,*">

      <!-- SIDEBAR (glass) -->
      <Border Grid.Column="0"
              Background="#25FFFFFF"
              BorderBrush="#20FFFFFF" BorderThickness="0,0,1,0">
        <ListBox ItemsSource="{Binding NavItems}"
                 SelectedItem="{Binding SelectedNavItem}"
                 SelectionMode="Single"
                 Background="Transparent"
                 BorderThickness="0"
                 Margin="10,16,10,10">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:NavItemViewModel">
              <StackPanel Orientation="Horizontal" Spacing="10" Margin="2,1">
                <mi:MaterialIcon Kind="{Binding Icon, Converter={StaticResource StringToIcon}}"
                                 Width="17" Height="17" VerticalAlignment="Center" />
                <TextBlock Text="{Binding Title}" FontSize="12"
                           FontWeight="Medium" VerticalAlignment="Center" />
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Padding" Value="12,9" />
              <Setter Property="CornerRadius" Value="10" />
              <Setter Property="Margin" Value="0,2" />
              <Setter Property="Foreground" Value="#6A8099" />
              <Setter Property="Cursor" Value="Hand" />
              <Setter Property="Transitions">
                <Transitions>
                  <BrushTransition Property="Foreground" Duration="0:0:0.15" />
                </Transitions>
              </Setter>
            </Style>
            <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
              <Setter Property="Background">
                <SolidColorBrush Color="#1200F0C8" />
              </Setter>
            </Style>
            <Style Selector="ListBoxItem:pointerover">
              <Setter Property="Foreground" Value="#B0D8E8" />
            </Style>
            <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
              <Setter Property="Background">
                <SolidColorBrush Color="#2000F0C8" />
              </Setter>
            </Style>
            <Style Selector="ListBoxItem:selected">
              <Setter Property="Foreground" Value="#00F0C8" />
            </Style>
          </ListBox.Styles>
        </ListBox>
      </Border>

      <!-- MAIN CONTENT -->
      <ContentControl Grid.Column="1"
                      Content="{Binding CurrentPage}"
                      Background="Transparent" />
    </Grid>

    <!-- ═══ STATUS BAR (glass) ═══ -->
    <Border Grid.Row="2"
            Background="#12FFFFFF"
            BorderBrush="#1EFFFFFF" BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="*,*" Margin="20,0">
        <StackPanel Grid.Column="0" Orientation="Horizontal"
                    VerticalAlignment="Center" Spacing="8">
          <Ellipse Width="5" Height="5" VerticalAlignment="Center">
            <Ellipse.Fill>
              <SolidColorBrush Color="#00F0C8" />
            </Ellipse.Fill>
          </Ellipse>
          <TextBlock Text="FabSentinel v1.0.0 — Capstone Project"
                     FontSize="10" Foreground="#4A6880" VerticalAlignment="Center" />
        </StackPanel>
        <TextBlock Grid.Column="1"
                   Text=".NET 10.0 · Avalonia UI 11.2 · LiveCharts2 · MVVM"
                   FontSize="10" Foreground="#344050"
                   VerticalAlignment="Center" HorizontalAlignment="Right" />
      </Grid>
    </Border>

  </Grid>
</Window>
