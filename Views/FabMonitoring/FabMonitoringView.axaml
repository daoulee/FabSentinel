<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GreenVision.ViewModels"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             xmlns:converters="using:GreenVision.Converters"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:ai="using:AnimatedImage.Avalonia"
             x:Class="GreenVision.Views.FabMonitoringView"
             x:DataType="vm:FabMonitoringViewModel"
             Background="Transparent">

  <UserControl.Resources>
    <converters:StringToColorBrushConverter x:Key="StringToBrush" />
    <converters:StringToMaterialIconKindConverter x:Key="StringToIcon" />
  </UserControl.Resources>

  <Grid RowDefinitions="Auto,Auto,*" Margin="12">

    <!-- ═══ Row 0: Header + Risk Card ═══ -->
    <Grid Grid.Row="0" ColumnDefinitions="*,280" Margin="0,0,0,8">
      <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
        <TextBlock Text="Fab Environment Monitoring" Classes="page-title" />
        <TextBlock Text="Real-time environmental safety for semiconductor fabrication" Classes="muted" />
      </StackPanel>

      <Border Grid.Column="1" Background="#25FFFFFF" CornerRadius="12"
              BorderBrush="#30FFFFFF" BorderThickness="1" Padding="16,12">
        <Grid ColumnDefinitions="Auto,*">
          <Border Grid.Column="0" Width="52" Height="52" CornerRadius="26"
                  Background="{Binding RiskColor, Converter={StaticResource StringToBrush}}"
                  Margin="0,0,12,0">
            <mi:MaterialIcon Kind="{Binding RiskIcon, Converter={StaticResource StringToIcon}}"
                             Width="26" Height="26"
                             Foreground="White"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
            <TextBlock Text="RISK LEVEL" FontSize="10" Foreground="#6A8099" FontWeight="SemiBold" />
            <TextBlock Text="{Binding RiskLevel}" FontSize="18" FontWeight="Bold"
                       Foreground="{Binding RiskColor, Converter={StaticResource StringToBrush}}" />
            <TextBlock Text="{Binding RiskDescription}" FontSize="10" Foreground="#6A8099"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Grid>
      </Border>
    </Grid>

    <!-- ═══ Row 1: Tab Buttons ═══ -->
    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="0" Margin="0,0,0,8">
      <Button Classes="tab" Classes.tabactive="{Binding IsMonitorTab}"
              Command="{Binding SelectFabTabCommand}" CommandParameter="Monitor">
        Monitor
      </Button>
      <Button Classes="tab" Classes.tabactive="{Binding IsFloorPlanTab}"
              Command="{Binding SelectFabTabCommand}" CommandParameter="FloorPlan">
        Floor Plan
      </Button>
    </StackPanel>

    <!-- ═══ Row 2: Monitor Panel ═══ -->
    <Grid Grid.Row="2" RowDefinitions="*,*" IsVisible="{Binding IsMonitorTab}">

      <!-- Sensor array + Environment chart -->
      <Grid Grid.Row="0" ColumnDefinitions="*,*" Margin="0,0,0,8">
        <Border Grid.Column="0" Background="#25FFFFFF" CornerRadius="12"
                BorderBrush="#30FFFFFF" BorderThickness="1" Margin="0,0,6,0" Padding="16">
          <Grid RowDefinitions="Auto,*">
            <TextBlock Grid.Row="0" Text="Sensor Array" FontSize="13"
                       FontWeight="SemiBold" Foreground="#F0F6FF" Margin="0,0,0,12" />
            <ItemsControl Grid.Row="1" ItemsSource="{Binding AllSensors}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <UniformGrid Rows="2" Columns="3" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:SensorCardViewModel">
                  <Border Margin="4" Padding="12" CornerRadius="10" Background="#25FFFFFF">
                    <StackPanel Spacing="6">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <mi:MaterialIcon Kind="{Binding Icon, Converter={StaticResource StringToIcon}}"
                                         Width="15" Height="15"
                                         Foreground="{Binding StatusColor, Converter={StaticResource StringToBrush}}" />
                        <TextBlock Text="{Binding Name}" FontSize="11"
                                   Foreground="#6A8099" VerticalAlignment="Center" />
                      </StackPanel>
                      <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DisplayValue}" FontSize="20" FontWeight="Bold"
                                   Foreground="{Binding StatusColor, Converter={StaticResource StringToBrush}}" />
                        <TextBlock Text="{Binding Unit}" FontSize="10" Foreground="#6A8099"
                                   VerticalAlignment="Bottom" Margin="0,0,0,3" />
                      </StackPanel>
                      <ProgressBar Value="{Binding NormalizedValue}"
                                   Minimum="0" Maximum="1" Height="4" />
                      <TextBlock Text="{Binding StatusText}" FontSize="10" FontWeight="SemiBold"
                                 Foreground="{Binding StatusColor, Converter={StaticResource StringToBrush}}" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Grid>
        </Border>

        <Border Grid.Column="1" Background="#25FFFFFF" CornerRadius="12"
                BorderBrush="#30FFFFFF" BorderThickness="1" Margin="6,0,0,0">
          <Grid RowDefinitions="Auto,*">
            <StackPanel Grid.Row="0" Margin="16,12,16,4">
              <TextBlock Text="Temperature &amp; Humidity History" FontSize="13"
                         FontWeight="SemiBold" Foreground="#F0F6FF" />
              <TextBlock Text="60-minute rolling window" FontSize="11" Foreground="#6A8099" />
            </StackPanel>
            <lvc:CartesianChart Grid.Row="1"
                                Series="{Binding EnvironmentSeries}"
                                XAxes="{Binding XAxes}" YAxes="{Binding YAxes}"
                                LegendPosition="Top" Background="Transparent"
                                AnimationsSpeed="0:0:0.4"
                                Margin="8,0,8,8" />
          </Grid>
        </Border>
      </Grid>

      <!-- Gas chart + Calibration -->
      <Grid Grid.Row="1" ColumnDefinitions="*,300" Margin="0,0,0,0">
        <Border Grid.Column="0" Background="#25FFFFFF" CornerRadius="12"
                BorderBrush="#30FFFFFF" BorderThickness="1" Margin="0,0,6,0">
          <Grid RowDefinitions="Auto,*">
            <StackPanel Grid.Row="0" Margin="16,12,16,4">
              <TextBlock Text="Gas Concentration History" FontSize="13"
                         FontWeight="SemiBold" Foreground="#F0F6FF" />
              <TextBlock Text="PM2.5 · NH3 — 120-minute window" FontSize="11" Foreground="#6A8099" />
            </StackPanel>
            <lvc:CartesianChart Grid.Row="1"
                                Series="{Binding GasSeries}"
                                XAxes="{Binding XAxes}" YAxes="{Binding YAxes}"
                                LegendPosition="Top" Background="Transparent"
                                AnimationsSpeed="0:0:0.4"
                                Margin="8,0,8,8" />
          </Grid>
        </Border>

        <Border Grid.Column="1" Background="#25FFFFFF" CornerRadius="12"
                BorderBrush="#30FFFFFF" BorderThickness="1" Margin="6,0,0,0" Padding="16">
          <StackPanel Spacing="12">
            <TextBlock Text="Sensor Calibration" FontSize="13"
                       FontWeight="SemiBold" Foreground="#F0F6FF" />
            <TextBlock Text="Sensor" FontSize="11" Foreground="#6A8099" />
            <ComboBox SelectedIndex="0" HorizontalAlignment="Stretch">
              <ComboBoxItem>Temperature</ComboBoxItem>
              <ComboBoxItem>Humidity</ComboBoxItem>
              <ComboBoxItem>PM2.5</ComboBoxItem>
              <ComboBoxItem>PM10</ComboBoxItem>
              <ComboBoxItem>NH3</ComboBoxItem>
              <ComboBoxItem>CO</ComboBoxItem>
            </ComboBox>
            <TextBlock Text="Offset Adjustment" FontSize="11" Foreground="#6A8099" />
            <NumericUpDown Value="{Binding CalibrationOffset}"
                           Minimum="-10" Maximum="10" Increment="0.1"
                           FormatString="F2" />
            <Button Content="Apply Calibration" Classes="primary"
                    Command="{Binding ApplyCalibrationCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center" />
            <Border Height="1" Background="#20FFFFFF" />
            <TextBlock Text="Last calibrated: 2025-06-28 09:15" FontSize="10" Foreground="#6A8099" />
            <TextBlock Text="Calibration source: NIST Reference" FontSize="10" Foreground="#6A8099" />
          </StackPanel>
        </Border>
      </Grid>
    </Grid>

    <!-- ═══ Row 2: Floor Plan (Video Overlay) Panel ═══ -->
    <Border Grid.Row="2" CornerRadius="12" ClipToBounds="True"
            BorderBrush="#30FFFFFF" BorderThickness="1"
            IsVisible="{Binding IsFloorPlanTab}">
      <Grid RowDefinitions="Auto,*">

        <!-- Header bar -->
        <Border Grid.Row="0" Background="#CC050A14" Padding="16,10" ZIndex="10">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
              <Border CornerRadius="5" Padding="8,3" Background="#B0FF2244">
                <StackPanel Orientation="Horizontal" Spacing="5">
                  <Ellipse Width="6" Height="6" Fill="White" VerticalAlignment="Center" />
                  <TextBlock Text="LIVE" FontSize="10" Foreground="White" FontWeight="Bold" />
                </StackPanel>
              </Border>
              <StackPanel Spacing="1" VerticalAlignment="Center">
                <TextBlock Text="Fab Live View · Zone A" FontSize="13"
                           FontWeight="SemiBold" Foreground="#F0F6FF" />
                <TextBlock Text="Real-time sensor overlay · Semiconductor clean room · ISO Class 5"
                           FontSize="10" Foreground="#6A8099" />
              </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <Border CornerRadius="5" Padding="7,3" Background="#1500E896" BorderBrush="#3000E896" BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <Ellipse Width="6" Height="6" Fill="#00E896" VerticalAlignment="Center" />
                  <TextBlock Text="NORMAL" FontSize="9" Foreground="#00E896" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
              <Border CornerRadius="5" Padding="7,3" Background="#15FFB300" BorderBrush="#30FFB300" BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <Ellipse Width="6" Height="6" Fill="#FFB300" VerticalAlignment="Center" />
                  <TextBlock Text="WARNING" FontSize="9" Foreground="#FFB300" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
              <Border CornerRadius="5" Padding="7,3" Background="#15FF4466" BorderBrush="#30FF4466" BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <Ellipse Width="6" Height="6" Fill="#FF4466" VerticalAlignment="Center" />
                  <TextBlock Text="DANGER" FontSize="9" Foreground="#FF4466" FontWeight="SemiBold" />
                </StackPanel>
              </Border>
            </StackPanel>
          </Grid>
        </Border>

        <!-- Video + sensor overlay stack -->
        <Grid Grid.Row="1">

          <!-- Layer 0: Virtual Fab Floor Plan -->
          <Grid Background="#04080F">
            <Grid RowDefinitions="*,20,68" IsHitTestVisible="False">

              <!-- ── PRODUCTION BAYS ── -->
              <Grid Grid.Row="0" ColumnDefinitions="*,2,*,2,*,2,*">

                <!-- Zone A: Lithography — Blue -->
                <Border Grid.Column="0" Background="#07101C">
                  <Grid RowDefinitions="30,*,24">
                    <Border Grid.Row="0" Background="#0B1826" BorderBrush="#1A4060" BorderThickness="0,0,0,1">
                      <Grid ColumnDefinitions="3,*">
                        <Border Width="3" Background="#0077CC"/>
                        <StackPanel Margin="8,0" VerticalAlignment="Center" Spacing="0">
                          <TextBlock Text="ZONE A  ·  LITHO" FontSize="8" Foreground="#4AABE6"
                                     FontWeight="Bold" FontFamily="Consolas,Courier New,monospace"/>
                          <TextBlock Text="Photolithography" FontSize="7" Foreground="#2A6888"/>
                        </StackPanel>
                      </Grid>
                    </Border>
                    <UniformGrid Grid.Row="1" Rows="6" Columns="1" Margin="5,4,5,4">
                      <Border Margin="0,1" Background="#0C1928" CornerRadius="3">
                        <Grid ColumnDefinitions="8,*,Auto" Margin="10,0" VerticalAlignment="Center">
                          <Ellipse Width="7" Height="7" Fill="#00E896" VerticalAlignment="Center"/>
                          <StackPanel Grid.Column="1" Margin="8,0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="SCANNER-A" FontSize="9" Foreground="#4AABE6" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold"/>
                            <TextBlock Text="EUV 193nm · Lot #A4821" FontSize="6.5" Foreground="#2A5878"/>
                          </StackPanel>
                          <Border Grid.Column="2" Background="#0A2A18" CornerRadius="3" Padding="7,2" VerticalAlignment="Center">
                            <TextBlock Text="RUN" FontSize="7" Foreground="#00E896" FontWeight="Bold" FontFamily="Consolas,Courier New,monospace"/>
                          </Border>
                        </Grid>
                      </Border>
                      <Border Margin="0,1" Background="#091522" CornerRadius="3">
                        <Grid ColumnDefinitions="8,*,Auto" Margin="10,0" VerticalAlignment="Center">
                          <Ellipse Width="7" Height="7" Fill="#FFB300" VerticalAlignment="Center"/>
                          <StackPanel Grid.Column="1" Margin="8,0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="SCANNER-B" FontSize="9" Foreground="#4AABE6" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold"/>
                            <TextBlock Text="ArF Immersion · Standby" FontSize="6.5" Foreground="#2A5878"/>
                          </StackPanel>
                          <Border Grid.Column="2" Background="#2A1A00" CornerRadius="3" Padding="7,2" VerticalAlignment="Center">
                            <TextBlock Text="IDLE" FontSize="7" Foreground="#FFB300" FontWeight="Bold" FontFamily="Consolas,Courier New,monospace"/>
                          </Border>
                        </Grid>
                      </Border>
                      <Border Margin="0,1" Background="#0C1928" CornerRadius="3">
                        <Grid ColumnDefinitions="8,*,Auto" Margin="10,0" VerticalAlignment="Center">
                          <Ellipse Width="7" Height="7" Fill="#00E896" VerticalAlignment="Center"/>
                          <StackPanel Grid.Column="1" Margin="8,0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="TRACK-1" FontSize="9" Foreground="#4AABE6" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold"/>
                            <TextBlock Text="Resist Coat · Lot #A4820" FontSize="6.5" Foreground="#2A5878"/>
                          </StackPanel>
                          <Border Grid.Column="2" Background="#0A2A18" CornerRadius="3" Padding="7,2" VerticalAlignment="Center">
                            <TextBlock Text="RUN" FontSize="7" Foreground="#00E896" FontWeight="Bold" FontFamily="Consolas,Courier New,monospace"/>
                          </Border>
                        </Grid>
                      </Border>
                      <Border Margin="0,1" Background="#091522" CornerRadius="3">
                        <Grid ColumnDefinitions="8,*,Auto" Margin="10,0" VerticalAlignment="Center">
                          <Ellipse Width="7" Height="7" Fill="#00E896" VerticalAlignment="Center"/>
                          <StackPanel Grid.Column="1" Margin="8,0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="COATER-A" FontSize="9" Foreground="#4AABE6" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold"/>
                            <TextBlock Text="Resist TARC · Lot #A4819" FontSize="6.5" Foreground="#2A5878"/>
                          </StackPanel>
                          <Border Grid.Column="2" Background="#0A2A18" CornerRadius="3" Padding="7,2" VerticalAlignment="Center">
                            <TextBlock Text="RUN" FontSize="7" Foreground="#00E896" FontWeight="Bold" FontFamily="Consolas,Courier New,monospace"/>
                          </Border>
                        </Grid>
                      </Border>
                      <Border Margin="0,1" Background="#0C1928" CornerRadius="3">
                        <Grid ColumnDefinitions="8,*,Auto" Margin="10,0" VerticalAlignment="Center">
                          <Ellipse Width="7" Height="7" Fill="#00E896" VerticalAlignment="Center"/>
                          <StackPanel Grid.Column="1" Margin="8,0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="COATER-B" FontSize="9" Foreground="#4AABE6" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold"/>
                            <TextBlock Text="Resist OPL · Active" FontSize="6.5" Foreground="#2A5878"/>
                          </StackPanel>
                          <Border Grid.Column="2" Background="#0A2A18" CornerRadius="3" Padding="7,2" VerticalAlignment="Center">
                            <TextBlock Text="RUN" FontSize="7" Foreground="#00E896" FontWeight="Bold" FontFamily="Consolas,Courier New,monospace"/>
                          </Border>
                        </Grid>
                      </Border>
                      <Border Margin="0,1" Background="#091522" CornerRadius="3">
                        <Grid ColumnDefinitions="8,*,Auto" Margin="10,0" VerticalAlignment="Center">
                          <Ellipse Width="7" Height="7" Fill="#00E896" VerticalAlignment="Center"/>
                          <StackPanel Grid.Column="1" Margin="8,0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="DEVELOP" FontSize="9" Foreground="#4AABE6" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold"/>
                            <TextBlock Text="TMAH Dev · Lot #A4818" FontSize="6.5" Foreground="#2A5878"/>
                          </StackPanel>
                          <Border Grid.Column="2" Background="#0A2A18" CornerRadius="3" Padding="7,2" VerticalAlignment="Center">
                            <TextBlock Text="RUN" FontSize="7" Foreground="#00E896" FontWeight="Bold" FontFamily="Consolas,Courier New,monospace"/>
                          </Border>
                        </Grid>
                      </Border>
                    </UniformGrid>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="10,0">
                      <Ellipse Width="8" Height="8" Fill="{Binding AllSensors[0].StatusColor, Converter={StaticResource StringToBrush}}"/>
                      <TextBlock Text="PM2.5 SENSOR" FontSize="7" Foreground="#2A6888" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Grid>
                </Border>

                <Border Grid.Column="1" Background="#020508"/>

                <!-- Zone B: Plasma Etch — Purple -->
                <Border Grid.Column="2" Background="#0D0918">
                  <Grid RowDefinitions="30,*,24">
                    <Border Grid.Row="0" Background="#120D20" BorderBrush="#2E1860" BorderThickness="0,0,0,1">
                      <Grid ColumnDefinitions="3,*">
                        <Border Width="3" Background="#7744CC"/>
                        <StackPanel Margin="8,0" VerticalAlignment="Center" Spacing="0">
                          <TextBlock Text="ZONE B  ·  ETCH" FontSize="8" Foreground="#9966EE"
                                     FontWeight="Bold" FontFamily="Consolas,Courier New,monospace"/>
                          <TextBlock Text="Plasma Etch" FontSize="7" Foreground="#5A3898"/>
                        </StackPanel>
                      </Grid>
                    </Border>
                    <UniformGrid Grid.Row="1" Rows="6" Columns="1" Margin="5,4,5,4">
                      <Border Margin="0,1" Background="#130D22" CornerRadius="3">
                        <Grid ColumnDefinitions="8,*,Auto" Margin="10,0" VerticalAlignment="Center">
                          <Ellipse Width="7" Height="7" Fill="#00E896" VerticalAlignment="Center"/>
                          <StackPanel Grid.Column="1" Margin="8,0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="ICP-1" FontSize="9" Foreground="#9966EE" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold"/>
                            <TextBlock Text="Si Etch · Lot #B2341" FontSize="6.5" Foreground="#3A2870"/>
                          </StackPanel>
                          <Border Grid.Column="2" Background="#0A2A18" CornerRadius="3" Padding="7,2" VerticalAlignment="Center">
                            <TextBlock Text="RUN" FontSize="7" Foreground="#00E896" FontWeight="Bold" FontFamily="Consolas,Courier New,monospace"/>
                          </Border>
                        </Grid>
                      </Border>
                      <Border Margin="0,1" Background="#100B1E" CornerRadius="3">
                        <Grid ColumnDefinitions="8,*,Auto" Margin="10,0" VerticalAlignment="Center">
                          <Ellipse Width="7" Height="7" Fill="#00E896" VerticalAlignment="Center"/>
                          <StackPanel Grid.Column="1" Margin="8,0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="ICP-2" FontSize="9" Foreground="#9966EE" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold"/>
                            <TextBlock Text="Metal Etch · Lot #B2339" FontSize="6.5" Foreground="#3A2870"/>
                          </StackPanel>
                          <Border Grid.Column="2" Background="#0A2A18" CornerRadius="3" Padding="7,2" VerticalAlignment="Center">
                            <TextBlock Text="RUN" FontSize="7" Foreground="#00E896" FontWeight="Bold" FontFamily="Consolas,Courier New,monospace"/>
                          </Border>
                        </Grid>
                      </Border>
                      <Border Margin="0,1" Background="#130D22" CornerRadius="3">
                        <Grid ColumnDefinitions="8,*,Auto" Margin="10,0" VerticalAlignment="Center">
                          <Ellipse Width="7" Height="7" Fill="#FFB300" VerticalAlignment="Center"/>
                          <StackPanel Grid.Column="1" Margin="8,0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="ICP-3" FontSize="9" Foreground="#9966EE" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold"/>
                            <TextBlock Text="Chamber Clean" FontSize="6.5" Foreground="#3A2870"/>
                          </StackPanel>
                          <Border Grid.Column="2" Background="#2A1A00" CornerRadius="3" Padding="7,2" VerticalAlignment="Center">
                            <TextBlock Text="IDLE" FontSize="7" Foreground="#FFB300" FontWeight="Bold" FontFamily="Consolas,Courier New,monospace"/>
                          </Border>
                        </Grid>
                      </Border>
                      <Border Margin="0,1" Background="#100B1E" CornerRadius="3">
                        <Grid ColumnDefinitions="8,*,Auto" Margin="10,0" VerticalAlignment="Center">
                          <Ellipse Width="7" Height="7" Fill="#00E896" VerticalAlignment="Center"/>
                          <StackPanel Grid.Column="1" Margin="8,0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="CCP-1" FontSize="9" Foreground="#9966EE" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold"/>
                            <TextBlock Text="Oxide Etch · Active" FontSize="6.5" Foreground="#3A2870"/>
                          </StackPanel>
                          <Border Grid.Column="2" Background="#0A2A18" CornerRadius="3" Padding="7,2" VerticalAlignment="Center">
                            <TextBlock Text="RUN" FontSize="7" Foreground="#00E896" FontWeight="Bold" FontFamily="Consolas,Courier New,monospace"/>
                          </Border>
                        </Grid>
                      </Border>
                      <Border Margin="0,1" Background="#130D22" CornerRadius="3">
                        <Grid ColumnDefinitions="8,*,Auto" Margin="10,0" VerticalAlignment="Center">
                          <Ellipse Width="7" Height="7" Fill="#00E896" VerticalAlignment="Center"/>
                          <StackPanel Grid.Column="1" Margin="8,0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="CCP-2" FontSize="9" Foreground="#9966EE" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold"/>
                            <TextBlock Text="SiN Etch · Lot #B2340" FontSize="6.5" Foreground="#3A2870"/>
                          </StackPanel>
                          <Border Grid.Column="2" Background="#0A2A18" CornerRadius="3" Padding="7,2" VerticalAlignment="Center">
                            <TextBlock Text="RUN" FontSize="7" Foreground="#00E896" FontWeight="Bold" FontFamily="Consolas,Courier New,monospace"/>
                          </Border>
                        </Grid>
                      </Border>
                      <Border Margin="0,1" Background="#100B1E" CornerRadius="3">
                        <Grid ColumnDefinitions="8,*,Auto" Margin="10,0" VerticalAlignment="Center">
                          <Ellipse Width="7" Height="7" Fill="#4A7090" VerticalAlignment="Center"/>
                          <StackPanel Grid.Column="1" Margin="8,0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="WET-BENCH" FontSize="9" Foreground="#9966EE" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold"/>
                            <TextBlock Text="DHF Clean · Standby" FontSize="6.5" Foreground="#3A2870"/>
                          </StackPanel>
                          <Border Grid.Column="2" Background="#0A1020" CornerRadius="3" Padding="7,2" VerticalAlignment="Center">
                            <TextBlock Text="STD" FontSize="7" Foreground="#4A7090" FontWeight="Bold" FontFamily="Consolas,Courier New,monospace"/>
                          </Border>
                        </Grid>
                      </Border>
                    </UniformGrid>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="10,0">
                      <Ellipse Width="8" Height="8" Fill="{Binding AllSensors[2].StatusColor, Converter={StaticResource StringToBrush}}"/>
                      <TextBlock Text="NH₃ SENSOR" FontSize="7" Foreground="#5A3898" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Grid>
                </Border>

                <Border Grid.Column="3" Background="#020508"/>

                <!-- Zone C: CVD — Teal -->
                <Border Grid.Column="4" Background="#071310">
                  <Grid RowDefinitions="30,*,24">
                    <Border Grid.Row="0" Background="#091A15" BorderBrush="#154830" BorderThickness="0,0,0,1">
                      <Grid ColumnDefinitions="3,*">
                        <Border Width="3" Background="#00AA88"/>
                        <StackPanel Margin="8,0" VerticalAlignment="Center" Spacing="0">
                          <TextBlock Text="ZONE C  ·  CVD" FontSize="8" Foreground="#30C8A0"
                                     FontWeight="Bold" FontFamily="Consolas,Courier New,monospace"/>
                          <TextBlock Text="Deposition" FontSize="7" Foreground="#1A8060"/>
                        </StackPanel>
                      </Grid>
                    </Border>
                    <UniformGrid Grid.Row="1" Rows="6" Columns="1" Margin="5,4,5,4">
                      <Border Margin="0,1" Background="#0A1C16" CornerRadius="3">
                        <Grid ColumnDefinitions="8,*,Auto" Margin="10,0" VerticalAlignment="Center">
                          <Ellipse Width="7" Height="7" Fill="#00E896" VerticalAlignment="Center"/>
                          <StackPanel Grid.Column="1" Margin="8,0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="LPCVD-1" FontSize="9" Foreground="#30C8A0" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold"/>
                            <TextBlock Text="SiO₂ Dep · 850°C" FontSize="6.5" Foreground="#1A5040"/>
                          </StackPanel>
                          <Border Grid.Column="2" Background="#0A2A18" CornerRadius="3" Padding="7,2" VerticalAlignment="Center">
                            <TextBlock Text="RUN" FontSize="7" Foreground="#00E896" FontWeight="Bold" FontFamily="Consolas,Courier New,monospace"/>
                          </Border>
                        </Grid>
                      </Border>
                      <Border Margin="0,1" Background="#081812" CornerRadius="3">
                        <Grid ColumnDefinitions="8,*,Auto" Margin="10,0" VerticalAlignment="Center">
                          <Ellipse Width="7" Height="7" Fill="#00E896" VerticalAlignment="Center"/>
                          <StackPanel Grid.Column="1" Margin="8,0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="ALD-1" FontSize="9" Foreground="#30C8A0" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold"/>
                            <TextBlock Text="Al₂O₃ · 300 cycles" FontSize="6.5" Foreground="#1A5040"/>
                          </StackPanel>
                          <Border Grid.Column="2" Background="#0A2A18" CornerRadius="3" Padding="7,2" VerticalAlignment="Center">
                            <TextBlock Text="RUN" FontSize="7" Foreground="#00E896" FontWeight="Bold" FontFamily="Consolas,Courier New,monospace"/>
                          </Border>
                        </Grid>
                      </Border>
                      <Border Margin="0,1" Background="#0A1C16" CornerRadius="3">
                        <Grid ColumnDefinitions="8,*,Auto" Margin="10,0" VerticalAlignment="Center">
                          <Ellipse Width="7" Height="7" Fill="#FFB300" VerticalAlignment="Center"/>
                          <StackPanel Grid.Column="1" Margin="8,0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="ALD-2" FontSize="9" Foreground="#30C8A0" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold"/>
                            <TextBlock Text="HfO₂ · Standby" FontSize="6.5" Foreground="#1A5040"/>
                          </StackPanel>
                          <Border Grid.Column="2" Background="#2A1A00" CornerRadius="3" Padding="7,2" VerticalAlignment="Center">
                            <TextBlock Text="IDLE" FontSize="7" Foreground="#FFB300" FontWeight="Bold" FontFamily="Consolas,Courier New,monospace"/>
                          </Border>
                        </Grid>
                      </Border>
                      <Border Margin="0,1" Background="#081812" CornerRadius="3">
                        <Grid ColumnDefinitions="8,*,Auto" Margin="10,0" VerticalAlignment="Center">
                          <Ellipse Width="7" Height="7" Fill="#00E896" VerticalAlignment="Center"/>
                          <StackPanel Grid.Column="1" Margin="8,0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="PECVD" FontSize="9" Foreground="#30C8A0" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold"/>
                            <TextBlock Text="SiN Dep · Active" FontSize="6.5" Foreground="#1A5040"/>
                          </StackPanel>
                          <Border Grid.Column="2" Background="#0A2A18" CornerRadius="3" Padding="7,2" VerticalAlignment="Center">
                            <TextBlock Text="RUN" FontSize="7" Foreground="#00E896" FontWeight="Bold" FontFamily="Consolas,Courier New,monospace"/>
                          </Border>
                        </Grid>
                      </Border>
                      <Border Margin="0,1" Background="#0A1C16" CornerRadius="3">
                        <Grid ColumnDefinitions="8,*,Auto" Margin="10,0" VerticalAlignment="Center">
                          <Ellipse Width="7" Height="7" Fill="#00E896" VerticalAlignment="Center"/>
                          <StackPanel Grid.Column="1" Margin="8,0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="PVD" FontSize="9" Foreground="#30C8A0" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold"/>
                            <TextBlock Text="Ti/TiN · Lot #C1122" FontSize="6.5" Foreground="#1A5040"/>
                          </StackPanel>
                          <Border Grid.Column="2" Background="#0A2A18" CornerRadius="3" Padding="7,2" VerticalAlignment="Center">
                            <TextBlock Text="RUN" FontSize="7" Foreground="#00E896" FontWeight="Bold" FontFamily="Consolas,Courier New,monospace"/>
                          </Border>
                        </Grid>
                      </Border>
                      <Border Margin="0,1" Background="#081812" CornerRadius="3">
                        <Grid ColumnDefinitions="8,*,Auto" Margin="10,0" VerticalAlignment="Center">
                          <Ellipse Width="7" Height="7" Fill="#00E896" VerticalAlignment="Center"/>
                          <StackPanel Grid.Column="1" Margin="8,0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="EPI" FontSize="9" Foreground="#30C8A0" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold"/>
                            <TextBlock Text="Si Epi · 1050°C" FontSize="6.5" Foreground="#1A5040"/>
                          </StackPanel>
                          <Border Grid.Column="2" Background="#0A2A18" CornerRadius="3" Padding="7,2" VerticalAlignment="Center">
                            <TextBlock Text="RUN" FontSize="7" Foreground="#00E896" FontWeight="Bold" FontFamily="Consolas,Courier New,monospace"/>
                          </Border>
                        </Grid>
                      </Border>
                    </UniformGrid>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="10,0">
                      <Ellipse Width="8" Height="8" Fill="{Binding AllSensors[3].StatusColor, Converter={StaticResource StringToBrush}}"/>
                      <TextBlock Text="CO SENSOR" FontSize="7" Foreground="#1A8060" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Grid>
                </Border>

                <Border Grid.Column="5" Background="#020508"/>

                <!-- Zone D: Metrology — Amber -->
                <Border Grid.Column="6" Background="#110D05">
                  <Grid RowDefinitions="30,*,24">
                    <Border Grid.Row="0" Background="#181205" BorderBrush="#3C2808" BorderThickness="0,0,0,1">
                      <Grid ColumnDefinitions="3,*">
                        <Border Width="3" Background="#CC8800"/>
                        <StackPanel Margin="8,0" VerticalAlignment="Center" Spacing="0">
                          <TextBlock Text="ZONE D  ·  METRO" FontSize="8" Foreground="#CC9933"
                                     FontWeight="Bold" FontFamily="Consolas,Courier New,monospace"/>
                          <TextBlock Text="Metrology" FontSize="7" Foreground="#7A5820"/>
                        </StackPanel>
                      </Grid>
                    </Border>
                    <UniformGrid Grid.Row="1" Rows="6" Columns="1" Margin="5,4,5,4">
                      <Border Margin="0,1" Background="#181205" CornerRadius="3">
                        <Grid ColumnDefinitions="8,*,Auto" Margin="10,0" VerticalAlignment="Center">
                          <Ellipse Width="7" Height="7" Fill="#00E896" VerticalAlignment="Center"/>
                          <StackPanel Grid.Column="1" Margin="8,0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="CD-SEM" FontSize="9" Foreground="#CC9933" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold"/>
                            <TextBlock Text="Gate CD · Lot #D7701" FontSize="6.5" Foreground="#5A3A10"/>
                          </StackPanel>
                          <Border Grid.Column="2" Background="#0A2A18" CornerRadius="3" Padding="7,2" VerticalAlignment="Center">
                            <TextBlock Text="RUN" FontSize="7" Foreground="#00E896" FontWeight="Bold" FontFamily="Consolas,Courier New,monospace"/>
                          </Border>
                        </Grid>
                      </Border>
                      <Border Margin="0,1" Background="#150E04" CornerRadius="3">
                        <Grid ColumnDefinitions="8,*,Auto" Margin="10,0" VerticalAlignment="Center">
                          <Ellipse Width="7" Height="7" Fill="#00E896" VerticalAlignment="Center"/>
                          <StackPanel Grid.Column="1" Margin="8,0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="E-SEM" FontSize="9" Foreground="#CC9933" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold"/>
                            <TextBlock Text="Defect Review · Active" FontSize="6.5" Foreground="#5A3A10"/>
                          </StackPanel>
                          <Border Grid.Column="2" Background="#0A2A18" CornerRadius="3" Padding="7,2" VerticalAlignment="Center">
                            <TextBlock Text="RUN" FontSize="7" Foreground="#00E896" FontWeight="Bold" FontFamily="Consolas,Courier New,monospace"/>
                          </Border>
                        </Grid>
                      </Border>
                      <Border Margin="0,1" Background="#181205" CornerRadius="3">
                        <Grid ColumnDefinitions="8,*,Auto" Margin="10,0" VerticalAlignment="Center">
                          <Ellipse Width="7" Height="7" Fill="#FFB300" VerticalAlignment="Center"/>
                          <StackPanel Grid.Column="1" Margin="8,0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="OCD" FontSize="9" Foreground="#CC9933" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold"/>
                            <TextBlock Text="Film Thickness · Standby" FontSize="6.5" Foreground="#5A3A10"/>
                          </StackPanel>
                          <Border Grid.Column="2" Background="#2A1A00" CornerRadius="3" Padding="7,2" VerticalAlignment="Center">
                            <TextBlock Text="IDLE" FontSize="7" Foreground="#FFB300" FontWeight="Bold" FontFamily="Consolas,Courier New,monospace"/>
                          </Border>
                        </Grid>
                      </Border>
                      <Border Margin="0,1" Background="#150E04" CornerRadius="3">
                        <Grid ColumnDefinitions="8,*,Auto" Margin="10,0" VerticalAlignment="Center">
                          <Ellipse Width="7" Height="7" Fill="#00E896" VerticalAlignment="Center"/>
                          <StackPanel Grid.Column="1" Margin="8,0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="OPTICAL-1" FontSize="9" Foreground="#CC9933" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold"/>
                            <TextBlock Text="Overlay · Lot #D7700" FontSize="6.5" Foreground="#5A3A10"/>
                          </StackPanel>
                          <Border Grid.Column="2" Background="#0A2A18" CornerRadius="3" Padding="7,2" VerticalAlignment="Center">
                            <TextBlock Text="RUN" FontSize="7" Foreground="#00E896" FontWeight="Bold" FontFamily="Consolas,Courier New,monospace"/>
                          </Border>
                        </Grid>
                      </Border>
                      <Border Margin="0,1" Background="#181205" CornerRadius="3">
                        <Grid ColumnDefinitions="8,*,Auto" Margin="10,0" VerticalAlignment="Center">
                          <Ellipse Width="7" Height="7" Fill="#00E896" VerticalAlignment="Center"/>
                          <StackPanel Grid.Column="1" Margin="8,0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="REVIEW" FontSize="9" Foreground="#CC9933" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold"/>
                            <TextBlock Text="Defect Class · Active" FontSize="6.5" Foreground="#5A3A10"/>
                          </StackPanel>
                          <Border Grid.Column="2" Background="#0A2A18" CornerRadius="3" Padding="7,2" VerticalAlignment="Center">
                            <TextBlock Text="RUN" FontSize="7" Foreground="#00E896" FontWeight="Bold" FontFamily="Consolas,Courier New,monospace"/>
                          </Border>
                        </Grid>
                      </Border>
                      <Border Margin="0,1" Background="#150E04" CornerRadius="3">
                        <Grid ColumnDefinitions="8,*,Auto" Margin="10,0" VerticalAlignment="Center">
                          <Ellipse Width="7" Height="7" Fill="#4A7090" VerticalAlignment="Center"/>
                          <StackPanel Grid.Column="1" Margin="8,0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="ADC" FontSize="9" Foreground="#CC9933" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold"/>
                            <TextBlock Text="Auto Defect · Standby" FontSize="6.5" Foreground="#5A3A10"/>
                          </StackPanel>
                          <Border Grid.Column="2" Background="#0A1020" CornerRadius="3" Padding="7,2" VerticalAlignment="Center">
                            <TextBlock Text="STD" FontSize="7" Foreground="#4A7090" FontWeight="Bold" FontFamily="Consolas,Courier New,monospace"/>
                          </Border>
                        </Grid>
                      </Border>
                    </UniformGrid>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="10,0">
                      <Ellipse Width="8" Height="8" Fill="{Binding AllSensors[4].StatusColor, Converter={StaticResource StringToBrush}}"/>
                      <TextBlock Text="TEMP SENSOR" FontSize="7" Foreground="#7A5820" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Grid>
                </Border>

              </Grid>

              <!-- ── MAIN AISLE ── -->
              <Border Grid.Row="1" Background="#060C16" BorderBrush="#0F2235" BorderThickness="0,1,0,1">
                <Grid ColumnDefinitions="Auto,*,Auto" Margin="16,0">
                  <TextBlock Grid.Column="0" Text="━  MAIN AISLE" FontSize="7.5" Foreground="#2A5878"
                             FontFamily="Consolas,Courier New,monospace" VerticalAlignment="Center" FontWeight="SemiBold"/>
                  <Border Grid.Column="1" Height="1" Background="#142A3E" VerticalAlignment="Center" Margin="10,0"/>
                  <TextBlock Grid.Column="2" Text="ISO CLASS 5  ·  SEMICONDUCTOR CLEAN ROOM  ━" FontSize="7.5" Foreground="#2A5878"
                             FontFamily="Consolas,Courier New,monospace" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </Grid>
              </Border>

              <!-- ── SUPPORT ZONES ── -->
              <Grid Grid.Row="2" ColumnDefinitions="*,1,*,1,*">

                <!-- HVAC / FFU -->
                <Border Grid.Column="0" Background="#070E18" BorderBrush="#102030" BorderThickness="0,0,0,1">
                  <Grid RowDefinitions="22,*">
                    <Border Grid.Row="0" Background="#08111E" BorderBrush="#142840" BorderThickness="0,0,0,1" Padding="10,0">
                      <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                        <TextBlock Grid.Column="0" Text="HVAC / FFU" FontSize="7.5" Foreground="#2A6888"
                                   FontWeight="Bold" FontFamily="Consolas,Courier New,monospace" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Fan Filter Unit Array" FontSize="7" Foreground="#1A3E54"
                                   FontFamily="Consolas,Courier New,monospace" VerticalAlignment="Center"/>
                      </Grid>
                    </Border>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="10,0">
                      <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                               Fill="{Binding AllSensors[1].StatusColor, Converter={StaticResource StringToBrush}}"/>
                      <TextBlock Text="PM10 SENSOR" FontSize="7" Foreground="#1E5070"
                                 FontFamily="Consolas,Courier New,monospace" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                  </Grid>
                </Border>

                <Border Grid.Column="1" Background="#020508"/>

                <!-- CDA / Chemical -->
                <Border Grid.Column="2" Background="#070E18" BorderBrush="#102030" BorderThickness="0,0,0,1">
                  <Grid RowDefinitions="22,*">
                    <Border Grid.Row="0" Background="#08111E" BorderBrush="#142840" BorderThickness="0,0,0,1" Padding="10,0">
                      <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                        <TextBlock Grid.Column="0" Text="CDA / CHEMICAL" FontSize="7.5" Foreground="#2A6888"
                                   FontWeight="Bold" FontFamily="Consolas,Courier New,monospace" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Clean Dry Air · Distribution" FontSize="7" Foreground="#1A3E54"
                                   FontFamily="Consolas,Courier New,monospace" VerticalAlignment="Center"/>
                      </Grid>
                    </Border>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="10,0">
                      <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                               Fill="{Binding AllSensors[5].StatusColor, Converter={StaticResource StringToBrush}}"/>
                      <TextBlock Text="HUMIDITY SENSOR" FontSize="7" Foreground="#1E5070"
                                 FontFamily="Consolas,Courier New,monospace" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                  </Grid>
                </Border>

                <Border Grid.Column="3" Background="#020508"/>

                <!-- EHS / Gowning -->
                <Border Grid.Column="4" Background="#070E18" BorderBrush="#102030" BorderThickness="0,0,0,1">
                  <Grid RowDefinitions="22,*">
                    <Border Grid.Row="0" Background="#08111E" BorderBrush="#142840" BorderThickness="0,0,0,1" Padding="10,0">
                      <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                        <TextBlock Grid.Column="0" Text="GOWNING / EHS" FontSize="7.5" Foreground="#2A6888"
                                   FontWeight="Bold" FontFamily="Consolas,Courier New,monospace" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Environmental Health &amp; Safety" FontSize="7" Foreground="#1A3E54"
                                   FontFamily="Consolas,Courier New,monospace" VerticalAlignment="Center"/>
                      </Grid>
                    </Border>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="10,0">
                      <Ellipse Width="8" Height="8" Fill="#2A6888" VerticalAlignment="Center"/>
                      <TextBlock Text="EHS STATION" FontSize="7" Foreground="#1E5070"
                                 FontFamily="Consolas,Courier New,monospace" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                  </Grid>
                </Border>

              </Grid>

            </Grid>
          </Grid>

          <!-- Layer 3: Sensor HUD overlay -->
          <Grid RowDefinitions="Auto,*,Auto" Margin="12,10,12,10" IsHitTestVisible="False">

            <!-- Top sensor row: PM2.5  PM10  NH3 -->
            <UniformGrid Grid.Row="0" Columns="3">

              <!-- PM2.5 -->
              <Border Margin="4" Padding="10,8" CornerRadius="10"
                      Background="#C8050A14" BorderBrush="#4000F0C8" BorderThickness="1">
                <Grid ColumnDefinitions="Auto,*">
                  <Ellipse Grid.Column="0" Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0"
                           Fill="{Binding AllSensors[0].StatusColor, Converter={StaticResource StringToBrush}}" />
                  <StackPanel Grid.Column="1" Spacing="1">
                    <TextBlock Text="PM2.5" FontSize="9" Foreground="#6A8099" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="3">
                      <TextBlock Text="{Binding AllSensors[0].DisplayValue}" FontSize="18" FontWeight="Bold"
                                 Foreground="{Binding AllSensors[0].StatusColor, Converter={StaticResource StringToBrush}}" />
                      <TextBlock Text="μg/m³" FontSize="9" Foreground="#3A6080" VerticalAlignment="Bottom" Margin="0,0,0,2" />
                    </StackPanel>
                    <TextBlock Text="{Binding AllSensors[0].StatusText}" FontSize="9"
                               Foreground="{Binding AllSensors[0].StatusColor, Converter={StaticResource StringToBrush}}" />
                  </StackPanel>
                </Grid>
              </Border>

              <!-- PM10 -->
              <Border Margin="4" Padding="10,8" CornerRadius="10"
                      Background="#C8050A14" BorderBrush="#4000F0C8" BorderThickness="1">
                <Grid ColumnDefinitions="Auto,*">
                  <Ellipse Grid.Column="0" Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0"
                           Fill="{Binding AllSensors[1].StatusColor, Converter={StaticResource StringToBrush}}" />
                  <StackPanel Grid.Column="1" Spacing="1">
                    <TextBlock Text="PM10" FontSize="9" Foreground="#6A8099" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="3">
                      <TextBlock Text="{Binding AllSensors[1].DisplayValue}" FontSize="18" FontWeight="Bold"
                                 Foreground="{Binding AllSensors[1].StatusColor, Converter={StaticResource StringToBrush}}" />
                      <TextBlock Text="μg/m³" FontSize="9" Foreground="#3A6080" VerticalAlignment="Bottom" Margin="0,0,0,2" />
                    </StackPanel>
                    <TextBlock Text="{Binding AllSensors[1].StatusText}" FontSize="9"
                               Foreground="{Binding AllSensors[1].StatusColor, Converter={StaticResource StringToBrush}}" />
                  </StackPanel>
                </Grid>
              </Border>

              <!-- NH3 -->
              <Border Margin="4" Padding="10,8" CornerRadius="10"
                      Background="#C8050A14" BorderBrush="#4000F0C8" BorderThickness="1">
                <Grid ColumnDefinitions="Auto,*">
                  <Ellipse Grid.Column="0" Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0"
                           Fill="{Binding AllSensors[2].StatusColor, Converter={StaticResource StringToBrush}}" />
                  <StackPanel Grid.Column="1" Spacing="1">
                    <TextBlock Text="NH₃" FontSize="9" Foreground="#6A8099" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="3">
                      <TextBlock Text="{Binding AllSensors[2].DisplayValue}" FontSize="18" FontWeight="Bold"
                                 Foreground="{Binding AllSensors[2].StatusColor, Converter={StaticResource StringToBrush}}" />
                      <TextBlock Text="ppm" FontSize="9" Foreground="#3A6080" VerticalAlignment="Bottom" Margin="0,0,0,2" />
                    </StackPanel>
                    <TextBlock Text="{Binding AllSensors[2].StatusText}" FontSize="9"
                               Foreground="{Binding AllSensors[2].StatusColor, Converter={StaticResource StringToBrush}}" />
                  </StackPanel>
                </Grid>
              </Border>

            </UniformGrid>

            <!-- Middle: clean video window -->
            <Grid Grid.Row="1" />

            <!-- Bottom sensor row: CO  Temp  Humid -->
            <UniformGrid Grid.Row="2" Columns="3">

              <!-- CO -->
              <Border Margin="4" Padding="10,8" CornerRadius="10"
                      Background="#C8050A14" BorderBrush="#4000F0C8" BorderThickness="1">
                <Grid ColumnDefinitions="Auto,*">
                  <Ellipse Grid.Column="0" Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0"
                           Fill="{Binding AllSensors[3].StatusColor, Converter={StaticResource StringToBrush}}" />
                  <StackPanel Grid.Column="1" Spacing="1">
                    <TextBlock Text="CO" FontSize="9" Foreground="#6A8099" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="3">
                      <TextBlock Text="{Binding AllSensors[3].DisplayValue}" FontSize="18" FontWeight="Bold"
                                 Foreground="{Binding AllSensors[3].StatusColor, Converter={StaticResource StringToBrush}}" />
                      <TextBlock Text="ppm" FontSize="9" Foreground="#3A6080" VerticalAlignment="Bottom" Margin="0,0,0,2" />
                    </StackPanel>
                    <TextBlock Text="{Binding AllSensors[3].StatusText}" FontSize="9"
                               Foreground="{Binding AllSensors[3].StatusColor, Converter={StaticResource StringToBrush}}" />
                  </StackPanel>
                </Grid>
              </Border>

              <!-- Temperature -->
              <Border Margin="4" Padding="10,8" CornerRadius="10"
                      Background="#C8050A14" BorderBrush="#4000F0C8" BorderThickness="1">
                <Grid ColumnDefinitions="Auto,*">
                  <Ellipse Grid.Column="0" Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0"
                           Fill="{Binding AllSensors[4].StatusColor, Converter={StaticResource StringToBrush}}" />
                  <StackPanel Grid.Column="1" Spacing="1">
                    <TextBlock Text="TEMP" FontSize="9" Foreground="#6A8099" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="3">
                      <TextBlock Text="{Binding AllSensors[4].DisplayValue}" FontSize="18" FontWeight="Bold"
                                 Foreground="{Binding AllSensors[4].StatusColor, Converter={StaticResource StringToBrush}}" />
                      <TextBlock Text="°C" FontSize="9" Foreground="#3A6080" VerticalAlignment="Bottom" Margin="0,0,0,2" />
                    </StackPanel>
                    <TextBlock Text="{Binding AllSensors[4].StatusText}" FontSize="9"
                               Foreground="{Binding AllSensors[4].StatusColor, Converter={StaticResource StringToBrush}}" />
                  </StackPanel>
                </Grid>
              </Border>

              <!-- Humidity -->
              <Border Margin="4" Padding="10,8" CornerRadius="10"
                      Background="#C8050A14" BorderBrush="#4000F0C8" BorderThickness="1">
                <Grid ColumnDefinitions="Auto,*">
                  <Ellipse Grid.Column="0" Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0"
                           Fill="{Binding AllSensors[5].StatusColor, Converter={StaticResource StringToBrush}}" />
                  <StackPanel Grid.Column="1" Spacing="1">
                    <TextBlock Text="HUMID" FontSize="9" Foreground="#6A8099" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="3">
                      <TextBlock Text="{Binding AllSensors[5].DisplayValue}" FontSize="18" FontWeight="Bold"
                                 Foreground="{Binding AllSensors[5].StatusColor, Converter={StaticResource StringToBrush}}" />
                      <TextBlock Text="%" FontSize="9" Foreground="#3A6080" VerticalAlignment="Bottom" Margin="0,0,0,2" />
                    </StackPanel>
                    <TextBlock Text="{Binding AllSensors[5].StatusText}" FontSize="9"
                               Foreground="{Binding AllSensors[5].StatusColor, Converter={StaticResource StringToBrush}}" />
                  </StackPanel>
                </Grid>
              </Border>

            </UniformGrid>
          </Grid>

        </Grid>
      </Grid>
    </Border>

  </Grid>

  <UserControl.Styles>
    <Style Selector="Button.tab">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#6A8099" />
      <Setter Property="BorderThickness" Value="0,0,0,2" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Padding" Value="16,12" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="Button.tab.tabactive">
      <Setter Property="Foreground" Value="#00F0C8" />
      <Setter Property="BorderBrush" Value="#00F0C8" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.tab:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
  </UserControl.Styles>

</UserControl>
